# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ===== DEPENDENCIES =====
# Node.js dependencies
node_modules/
*/node_modules/
**/node_modules/
/.pnp
.pnp.js
package-lock.json
yarn.lock

# ===== ENVIRONMENT & SECRETS =====
# Environment files
.env
.env.*
*/.env
*/.env.*
**/.env
**/.env.*
!.env.example
.vscode/
*.cmd

# Environment directories
env/
*/env/
**/env/

# Security credentials (NEVER commit these!)
*.pem
*.key
*.cert
*.csr
*.p12
*.pfx
**/cert.pem
**/key.pem
**/csr.pem
**/private.key
**/refresh.key
secrets/
*/secrets/
**/secrets/

# ===== BUILD & TESTING =====
# Testing
/coverage
*.lcov
.nyc_output
/scripts/

# Production builds
/build
/dist
*/build/
*/dist/
**/build/
**/dist/

# ===== DOCKER =====
dockerfile
*dockerfile
Dockerfile
*Dockerfile
docker-compose.yml
*docker-compose.yml
docker-compose.yaml
*docker-compose.yaml
.dockerignore

# ===== LOGS =====
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# ===== OS & EDITOR FILES =====
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux
*~

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# ===== CACHE & TEMP =====
.cache/
.temp/
.tmp/
*.tmp
*.temp